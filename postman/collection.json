{
  "info": {
    "name": "Payment Gateway Manager API",
    "description": "API para gerenciar pagamentos entre múltiplos gateways com suporte a fallback automático",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3333/api/v1",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Autenticação",
      "item": [
        {
          "name": "Signup - Criar usuário",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "signup"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@test.com\",\n  \"password\": \"password123\",\n  \"passwordConfirmation\": \"password123\",\n  \"name\": \"Admin User\"\n}"
            }
          }
        },
        {
          "name": "Login - Autenticar",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@test.com\",\n  \"password\": \"password123\"\n}"
            },
            "event": [
              {
                "listen": "test",
                "script": {
                  "exec": [
                    "if (pm.response.code === 200) {",
                    "    var jsonData = pm.response.json();",
                    "    if (jsonData.data && jsonData.data.token) {",
                    "        pm.collectionVariables.set('token', jsonData.data.token);",
                    "    }",
                    "}"
                  ]
                }
              }
            ]
          }
        },
        {
          "name": "Logout - Sair",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Pagamentos",
      "item": [
        {
          "name": "Purchase - Realizar pagamento",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/purchase",
              "host": ["{{baseUrl}}"],
              "path": ["purchase"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"products\": [\n    {\"id\": 1, \"quantity\": 2}\n  ],\n  \"name\": \"João Silva\",\n  \"email\": \"joao@test.com\",\n  \"cardNumber\": \"4532123456789012\",\n  \"cvv\": \"123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Gateways",
      "item": [
        {
          "name": "List - Listar todos",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/gateways",
              "host": ["{{baseUrl}}"],
              "path": ["gateways"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Update - Atualizar",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/gateways/:id",
              "host": ["{{baseUrl}}"],
              "path": ["gateways", ":id"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isActive\": true,\n  \"priority\": 1\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Clientes",
      "item": [
        {
          "name": "List - Listar todos",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/clients",
              "host": ["{{baseUrl}}"],
              "path": ["clients"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Show - Detalhes",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/clients/:id",
              "host": ["{{baseUrl}}"],
              "path": ["clients", ":id"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Transações",
      "item": [
        {
          "name": "List - Listar todas",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/transactions",
              "host": ["{{baseUrl}}"],
              "path": ["transactions"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Show - Detalhes",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/transactions/:id",
              "host": ["{{baseUrl}}"],
              "path": ["transactions", ":id"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ]
          }
        },
        {
          "name": "Refund - Estornar",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/transactions/:id/refund",
              "host": ["{{baseUrl}}"],
              "path": ["transactions", ":id", "refund"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            }
          }
        }
      ]
    }
  ]
}
